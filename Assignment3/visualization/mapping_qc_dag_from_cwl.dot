digraph G {
bgcolor="#eeeeee";
clusterrank=local;
labelloc=bottom;
labeljust=right;
"index_reference" [fillcolor=lightgoldenrodyellow, style=filled, label="index_reference", shape=record];
"map" [fillcolor=lightgoldenrodyellow, style=filled, label=map, shape=record];
"index_reference" -> "map";
"run_flagstat" [fillcolor=lightgoldenrodyellow, style=filled, label="run_flagstat", shape=record];
"parse_flagstat" [fillcolor=lightgoldenrodyellow, style=filled, label="parse_flagstat", shape=record];
"run_flagstat" -> "parse_flagstat";
"sam_to_bam" [fillcolor=lightgoldenrodyellow, style=filled, label="sam_to_bam", shape=record];
"run_flagstat" [fillcolor=lightgoldenrodyellow, style=filled, label="run_flagstat", shape=record];
"sam_to_bam" -> "run_flagstat";
"map" [fillcolor=lightgoldenrodyellow, style=filled, label=map, shape=record];
"sam_to_bam" [fillcolor=lightgoldenrodyellow, style=filled, label="sam_to_bam", shape=record];
"map" -> "sam_to_bam";
"sam_to_bam" [fillcolor=lightgoldenrodyellow, style=filled, label="sam_to_bam", shape=record];
"sort_bam" [fillcolor=lightgoldenrodyellow, style=filled, label="sort_bam", shape=record];
"sam_to_bam" -> "sort_bam";
subgraph cluster_inputs {
rank=same;
style=dashed;
label="Workflow Inputs";
"reads" [fillcolor="#94DDF4", style=filled, label=reads, shape=record];
"reads" [fillcolor="#94DDF4", style=filled, label=reads, shape=record];
"reference" [fillcolor="#94DDF4", style=filled, label=reference, shape=record];
"threads" [fillcolor="#94DDF4", style=filled, label=threads, shape=record];
"threshold" [fillcolor="#94DDF4", style=filled, label=threshold, shape=record];
}
"reads" -> "fastqc";
"reads" -> "map";
"reference" -> "index_reference";
"threads" -> "map";
"threshold" -> "parse_flagstat";
subgraph cluster_outputs {
rank=same;
style=dashed;
label="Workflow Outputs";
labelloc=b;
"bam" [fillcolor="#94DDF4", style=filled, label=bam, shape=record];
"fastqc_html" [fillcolor="#94DDF4", style=filled, label="fastqc_html", shape=record];
"fastqc_zip" [fillcolor="#94DDF4", style=filled, label="fastqc_zip", shape=record];
"flagstat" [fillcolor="#94DDF4", style=filled, label=flagstat, shape=record];
"mapping_status" [fillcolor="#94DDF4", style=filled, label="mapping_status", shape=record];
"sam" [fillcolor="#94DDF4", style=filled, label=sam, shape=record];
"sorted_bam" [fillcolor="#94DDF4", style=filled, label="sorted_bam", shape=record];
}
"sam_to_bam" -> "bam";
"fastqc" -> "fastqc_html";
"fastqc" -> "fastqc_zip";
"run_flagstat" -> "flagstat";
"parse_flagstat" -> "mapping_status";
"map" -> "sam";
"sort_bam" -> "sorted_bam";
}
